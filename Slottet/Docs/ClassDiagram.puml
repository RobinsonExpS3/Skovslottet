      class StaffConfiguration
      class StaffPhoneConfiguration
      class StaffPNConfiguration
      class StaffResidentStatusConfiguration
      class StaffShiftConfiguration
    }

    package "Seed" as InfraSeed <<Folder>> {
      class DepartmentSeeder
      class DepartmentTaskSeeder
      class GroceryDaySeeder
      class MedicineSeeder
      class PaymentMethodSeeder
      class PhoneSeeder
      class PNSeeder
      class ResidentPaymentMethodSeeder
      class ResidentSeeder
      class ResidentStatusSeeder
      class RiskLevelSeeder
      class ShiftBoardSeeder
      class SpecialResponsibilitySeeder
      class StaffResidentStatusSeeder
      class StaffSeeder
      class StaffShiftSeeder
    }
  }

  package "Services" as InfraServices <<Folder>> {
    class AuditLogDTOService
    class MedicineDTOService
    class NoteMedicinDTOService
    class ResidentDTOService
    class ShiftBoardDTOService
    class StaffDTOService
    class StaffPNDTOService
    class SwapPhoneDTOService
  }

  class AuditScope
}

package "Slottet.Shared" as Shared <<Project>> {
