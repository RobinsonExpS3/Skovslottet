@startuml Slottet_Class_Diagram
title Slottet - Class diagram med projektmapper

skinparam packageStyle folder
skinparam linetype ortho
skinparam shadowing false
hide empty members
hide circle

package "Slottet" as SlottetRoot <<Project>> {
  package "Components/Layout" as RootLayout <<Folder>> {
    class NavMenu
  }

  package "Program" as RootProgram <<Folder>> {
    class RootProgramEntry <<Program>>
  }
}

package "Slottet.API" as API <<Project>> {
  package "Controllers" as APIControllers <<Folder>> {
    class AuditLogController
    class GroceryDayController
    class MedicineController
    class PaymentMethodController
    class PhoneController
    class ResidentController
    class ShiftboardController
    class SpecialResponsibilityController
    class StaffController
    class StaffPNController
    class SwapPhoneController
  }

  package "Middlewares" as APIMiddlewares <<Folder>> {
    class AuditScopeMiddleware
  }

  class APIProgram <<Program>>
}

package "Slottet.Application" as Application <<Project>> {
  package "Interfaces" as AppInterfaces <<Folder>> {
    interface IAuditLogDTOService
    interface IAuditScope {
      Guid? PerformedByStaffID
      string? PerformedByStaffName
      DateTime? PerformedAtTime
    }
    interface IMedicineDTOService
    interface INoteMedicineDTOService
    interface IResidentDTOService
    interface IShiftBoardDTOService
    interface IStaffDTOService
    interface IStaffPNDTOService
    interface ISwapPhoneDTOService
  }

  package "Services" as AppServices <<Folder>> {
    class Class1
  }
}

package "Slottet.Client" as Client <<Project>> {
  package "Components" as ClientComponents <<Folder>> {
    class DepartmentTaskComponent <<Razor>>
    class OverlayComponent <<Razor>>
    class PhoneListComponent <<Razor>>
    class ResidentCardComponent <<Razor>>
    class SpecialResponsibilityComponent <<Razor>>
  }

  package "Pages/AdminPages" as ClientAdminPages <<Folder>> {
    class AdminAudit <<Razor>>
    class AdminResident <<Razor>>
    class AdminSpecialResponsibility <<Razor>>
    class AdminStaff <<Razor>>
  }

  package "Pages/ShiftBoard" as ClientShiftBoardPages <<Folder>> {
    class ShiftBoardPage <<Razor>>
    enum OverlayPanel
    class BoundingRect <<record>>
  }
}

package "Slottet.Domain" as Domain <<Project>> {
  package "Entities" as DomainEntities <<Folder>> {
    class AuditLog {
      Guid AuditLogID
      DateTime TimeStamp
      string Action
      string TableName
      string KeyValues
    }

    class Department {
      Guid DepartmentID
      string DepartmentName
    }

    class DepartmentTask {
      Guid DepartmentTaskID
      string DepartmentTaskName
      Guid DepartmentID
    }

    class GroceryDay {
      Guid GroceryDayID
      string GroceryDayName
    }

    class Medicine {
      Guid MedicineID
      DateTime MedicineTime
      DateTime MedicineGivenTime
      DateTime MedicineRegisteredTime
      Guid ResidentID
    }

    class PaymentMethod {
      Guid PaymentMethodID
      string PaymentMethodName
    }

    class Phone {
      Guid PhoneID
      string PhoneNumber
      Guid DepartmentID
    }

    class PN {
      Guid PNID
      DateTime PNGivenTime
      string PNReason
      DateTime PNRegisteredTime
      Guid ResidentID
    }

    class Resident {
      Guid ResidentID
      string ResidentName
      bool IsActive
      Guid GroceryDayID
    }

    class ResidentPaymentMethod {
      Guid ResidentID
      Guid PaymentMethodID
    }

    class ResidentStatus {
      Guid ResidentStatusID
      string Status
      DateTime Date
      Guid ResidentID
      Guid RiskLevelID
    }

    class RiskLevel {
      Guid RiskLevelID
      string RiskLevelName
    }

    class ShiftBoard {
      Guid ShiftBoardID
      string ShiftType
      DateTime StartDateTime
      DateTime EndDateTime
    }

    class SpecialResponsibility {
      Guid SpecialResponsibilityID
      string TaskName
      Guid ShiftBoardID
    }

    class SpecialResponsibilityShiftBoard {
      Guid ShiftBoardID
      Guid SpecialResponsibilityID
    }

    class Staff {
      Guid StaffID
      string StaffName
      string Initials
      string Role
      Guid DepartmentID
    }

    class StaffPhone {
      Guid StaffID
      Guid PhoneID
      DateTime AssignedAt
    }

    class StaffPN {
      Guid StaffID
      Guid PNID
    }

    class StaffResidentStatus {
      Guid StaffID
      Guid ResidentStatusID
    }

    class StaffShift {
      Guid ShiftBoardID
      Guid StaffID
    }
  }
}

package "Slottet.Infrastructure" as Infrastructure <<Project>> {
  package "Auditing" as InfraAuditing <<Folder>> {
    class AuditInterceptor
  }

  package "Data" as InfraData <<Folder>> {
    class SlottetDBContext
