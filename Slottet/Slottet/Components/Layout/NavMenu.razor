@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Slottet</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <!-- Admin (collapsible) -->
        <div class="nav-item px-3">
            <button class="nav-link btn btn-link w-100 text-start" @onclick="ToggleAdminMenu">
                <span class="bi bi-list-nested-nav-menu"></span>
                Admin @(isAdminOpen ? "▼" : "▶")
            </button>
        </div>

        <!-- Admin submenu -->
        @if (isAdminOpen) {
            <div class="nav-item admin-nav-item">
                <NavLink class="nav-link" href="editResident">
                    <span class="bi bi-person-plus"></span> Beboer
                </NavLink>
            </div>

            <div class="nav-item admin-nav-item">
                <NavLink class="nav-link" href="editSpecialResponsibility">
                    <span class="bi bi-person-plus"></span> Særlige ansvar
                </NavLink>
            </div>
        }
    </nav>
</div>