@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Slottet</a>
    </div>

    <nav>
        <div>
            @* PLACEHOLDER *@
            <button class="nav-icon-btn" disabled>
                <i class="bi bi-list-ul"></i>
            </button>

            @* PLACEHOLDER *@
            <button class="nav-icon-btn" disabled>
                <i class="bi bi-card-text"></i>
            </button>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="shiftboard_viewonly">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Shiftboard View
            </NavLink>
        </div>

        <!-- Admin (collapsible) -->
        <div class="nav-item px-3">
            <button class="nav-link btn btn-link w-100 text-start" @onclick="ToggleAdminMenu">
                <span class="bi bi-list-nested-nav-menu"></span>
                Admin @(isAdminOpen ? "▼" : "▶")
            </button>
        </div>

        <!-- Admin submenu -->
        @if (isAdminOpen) {
            <div class="nav-item admin-nav-item">
                <NavLink class="nav-link" href="adminResident">
                    <span class="bi bi-person-plus"></span> Beboer
                </NavLink>
            </div>

            <div class="nav-item admin-nav-item">
                <NavLink class="nav-link" href="adminStaff">
                    <span class="bi bi-person-plus"></span> Personale
                </NavLink>
            </div>

            <div class="nav-item admin-nav-item">
                <NavLink class="nav-link" href="adminSpecialResponsibility">
                    <span class="bi bi-person-plus"></span> Særlige ansvar
                </NavLink>
            </div>

            <div class="nav-item admin-nav-item">
                <NavLink class="nav-link" href="adminAudit">
                    <span class="bi bi-person-plus"></span> Logs
                </NavLink>
            </div>
        }
    </nav>
</div>