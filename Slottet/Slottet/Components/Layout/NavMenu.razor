@rendermode InteractiveServer

<nav class="sidebar-nav">
    <div class="nav-top">

        @* Hjem *@
        <NavLink class="nav-icon-btn" href="/" Match="NavLinkMatch.All">
            <i class="bi bi-house-door-fill"></i>
        </NavLink>

        @* PLACEHOLDER *@
        <button class="nav-icon-btn" disabled>
            <i class="bi bi-list-ul"></i>
        </button>

        @* Vagtplan (view only) *@
        <NavLink class="nav-icon-btn" href="/shiftboard_viewonly" Match="NavLinkMatch.Prefix">
            <i class="bi bi-card-text"></i>
        </NavLink>

        @* Admin (collapsible) *@
        <button class="nav-icon-btn" @onclick="ToggleAdminMenu" title="Admin">
            <i class="bi bi-gear-fill"></i>
        </button>

        @if (isAdminOpen)
        {
            @* Admin-undermenu *@
            <div class="admin-submenu">
                <NavLink class="nav-icon-btn" href="adminResident" title="Beboere">
                    <i class="bi bi-person-plus"></i>
                </NavLink>
                <NavLink class="nav-icon-btn" href="adminStaff" title="Personale">
                    <i class="bi bi-people-fill"></i>
                </NavLink>
                <NavLink class="nav-icon-btn" href="adminSpecialResponsibility" title="Særlige ansvar">
                    <i class="bi bi-lock-fill"></i>
                </NavLink>
                <NavLink class="nav-icon-btn" href="adminAudit" title="Logs">
                    <i class="bi bi-journal-text"></i>
                </NavLink>
            </div>
        }

    </div>
</nav>

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Slottet</a>
    </div>
</div>
