@page "/adminAudit"
@rendermode InteractiveWebAssembly
@if (IsLoading)
{
    <p>Indlæser...</p>  
}
else if (ErrorMessage is not null)
{
    <p>@ErrorMessage</p>
}
else
{
    <div class="admin-page">

        <AdminHeader Active="audit" />

        <div class="admin-layout">
            <section class="admin-card">

                <div class="container">
                    <div class="top-bar">
                        <div class="date-picker">
                            <label for="audit-date">Dato</label>
                            <input id="audit-date" type="date" min="2026-04-01" value="@SelectedDateText" @onchange="OnDateChanged"/>
                        </div>

                        <div>
                            <label for="audit-shift">Vagt</label>
                            <select id="audit-shift" class="shift-picker" value="@SelectedShift" @onchange="OnShiftChanged">
                                <option value="">Vælg vagt</option>
                                <option value="day">Dag</option>
                                <option value="evening">Aften</option>
                                <option value="night">Nat</option>
                            </select>
                        </div>

                        <div class="audit-search">
                            <label for="audit-search">Søg</label>
                            <input id="audit-search"
                                   class="audit-search-input"
                                   type="search"
                                   placeholder="Søg i auditlog"
                                   value="@SearchText"
                                   @oninput="OnSearchInput" />
                        </div>

                    </div>

                    <div class="audit-panel">
                        @if (IsLoading)
                        {
                            <p>Indlæser audit logs...</p>
                        }
                        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
                        {
                            <p>@ErrorMessage</p>
                        }
                        else if (!FilteredGroups.Any())
                        {
                            <p>Ingen audit logs fundet.</p>
                        }
                        else
                        {
                            @foreach (var auditGroup in FilteredGroups)
                            {
                                var groupKey = auditGroup.Subject + "|" + auditGroup.ShiftBoard;
                                var expanded = IsGroupExpanded(groupKey);
                                <div class="audit-group">
                                    <div class="audit-group-header" @onclick="() => ToggleGroup(groupKey)">
                                        <span class="audit-group-chevron @(expanded ? "expanded" : "")">›</span>
                                        <span class="audit-group-subject">@auditGroup.Subject</span>
                                        @if (auditGroup.ShiftBoard != "–" && !string.IsNullOrWhiteSpace(auditGroup.ShiftBoard))
                                        {
                                            <span class="audit-group-badge">@auditGroup.ShiftBoard</span>
                                        }
                                        <span class="audit-group-meta">
                                            @auditGroup.LatestTime.ToString("HH:mm") · @auditGroup.Performers · @auditGroup.Rows.Count hændelse@(auditGroup.Rows.Count == 1 ? "" : "r")
                                        </span>
                                    </div>
                                    @if (expanded)
                                    {
                                        var hasDetails = auditGroup.Rows.Any(r =>
                                            !string.IsNullOrEmpty(ExtractDetail(r.Subject, auditGroup.Subject)));
                                        <table class="audit-table">
                                            <thead>
                                                <tr>
                                                    <th>Tid</th>
                                                    <th>Hvem</th>
                                                    <th>Handling</th>
                                                    <th>Kategori</th>
                                                    <th>Specificering</th>
                                                    <th>Ændret fra</th>
                                                    <th>Ændret til</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var row in auditGroup.Rows)
                                                {
                                                    var detail = hasDetails ? ExtractDetail(row.Subject, auditGroup.Subject) : string.Empty;
                                                    var fieldLabel = row.Field == "–" ? string.Empty : row.Field;
                                                    var spec = (detail, fieldLabel) switch
                                                    {
                                                        ({ Length: > 0 }, { Length: > 0 }) => $"{detail} · {fieldLabel}",
                                                        ({ Length: > 0 }, _)              => detail,
                                                        (_, { Length: > 0 })              => fieldLabel,
                                                        _                                  => "–"
                                                    };
                                                    <tr>
                                                        <td>@row.Time.ToString("HH:mm")</td>
                                                        <td class="audit-cell-muted">@row.PerformedBy</td>
                                                        <td>
                                                            <span class="audit-action @GetActionCssClass(row.Action)">@row.Action</span>
                                                        </td>
                                                        <td>@row.Category</td>
                                                        <td class="@(spec == "–" ? "audit-cell-muted" : "")">@spec</td>
                                                        <td class="@(row.OldValue == "–" ? "audit-cell-muted" : "")">@row.OldValue</td>
                                                        <td class="@(row.NewValue == "–" ? "audit-cell-muted" : "")">@row.NewValue</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </section>
        </div>
    </div>
}