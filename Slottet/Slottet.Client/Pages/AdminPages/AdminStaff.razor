@page "/adminStaff"
@rendermode InteractiveWebAssembly
@using Slottet.Shared

@if (isBusy)
{
    <p>Indlæser...</p>  
}
else if (loadErrorMessage is not null)
{
    <p>@loadErrorMessage</p>
}
else
{
    <div class="view-box" @onclick="ClearForm">
        <h2>Rediger personale</h2>
    
    
        <div class="table-layout">
            <table class="table-form" @onclick:stopPropagation>
                <thead>
                    <tr>
                        <th>Navn</th>
                        <th>Initialer</th>
                        <th>Rolle</th>
                        <th>Afdeling</th>
                    </tr>
                </thead>
                <tbody>
                    @if (loadFailed)
                    {
                        <tr>
                            <td colspan="4">@loadErrorMessage</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in staffMembers)
                        {
                            <tr @onclick="() => SelectItem(item)" class="@(selectedItem == item ? "selected-row" : "")">
                                <td>@item.StaffName</td>
                                <td>@item.Initials</td>
                                <td>@(item.Role == "staff" ? "Pædagog" : item.Role == "admin" ? "Administrator" : item.Role)</td>
                                <td>@GetDepartmentName(item.DepartmentID)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
    
            <div class="button-column" @onclick:stopPropagation>
                <p>
                    <strong>
                        @(selectedItem == null ? "Opret ny medarbejder" : "Rediger medarbejder")
                    </strong>
                </p>
              
                <input class="sp-table-input" @bind="staffNameInput" placeholder="Indtast navn" />
                <input class="sp-table-input" @bind="initialsInput" placeholder="Indtast initialer" />
                <select class="role-picker" @bind="roleInput">
                    <option value="">Vælg rolle</option>
                    <option value="staff">Pædagog</option>
                    <option value="admin">Administrator</option>
                </select>
                <select class="Deparment-picker" @bind="departmentIdInput">
                    <option value="@Guid.Empty">Vælg Afdeling</option>
                    @foreach (var department in departments)
                    {
                        <option value="@department.ID">@department.Name</option>
                    }
                </select>
                <button class="column-button" @onclick="Create" disabled="@(!CanCreate)">Opret</button>
                <button class="column-button" @onclick="Update" disabled="@(!CanUpdate)">Opdater</button>
                <button class="column-button" @onclick="Delete" disabled="@(!CanDelete)">Slet</button>
            </div>

            <div class="password-column">
                <p><strong id="formTitle">Opret kodeord</strong></p>

                <input id="passwordInput" type="password" placeholder="Indtast kodeord" />

                <button onclick="create()">Opret</button>
            </div>
        </div>
    </div>
}
