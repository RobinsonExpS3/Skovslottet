@page "/shiftboard_viewonly"

@if (Model is null)
{
	<p> Der er sket en fejl i indlæsningen af data </p>
}
else
{
	<section class="shiftboard-header">  @* Overskrift med afdelingens navn og vagttypen *@
		<h1>@Model.DepartmentName</h1>
		<p>
			<strong>Vagttype: </strong>@Model.ShiftType 
			<strong>Start: </strong>@Model.StartDate.ToString("dd-MM-yyyy HH:mm")
			<strong>Slut: </strong>@Model.EndDate.ToString("dd-MM-yyyy HH:mm")			
		</p>
	</section>
	
	<section class="shiftboard-layout">
	
		<main class="left-panel">

		<div class="resident-card-grid">			
				@foreach (var resident in Model.ResidentCards)
				{
					<article class="resident-card">
						<section class="resident-header @resident.RiskCssClass">
							<h3>@resident.ResidentName</h3>
						</section>

						<section class="resident-status">
							<h4>Seneste status</h4>
							<p>@resident.LatestStatusNote</p>
						</section>

						<section class="medicine-section">
							<table class="medicine-table">
								<thead>
									<tr>
										<th>Medicin</th>
										@foreach (var medicine in resident.MedicineSchedule)
										{
											<th>@medicine.Label</th>
										}
									</tr>
								</thead>

								<tbody>
									<tr>
										<td>Givet</td>
										@foreach (var medicine in resident.MedicineSchedule)
										{
											<td>
												<div class="dose-box @(medicine.IsGiven ? "given" : "not-given")">
													@(medicine.IsGiven ? "💊" : " ")
												</div>

											</td>
										}
									</tr>

									<tr>
										<td>PN</td>
										@foreach (var pn in resident.PnSchedule)
										{
											<td>
												<div class="dose-box @(pn.IsGiven ? "given" : "not-given")"">
													@(pn.IsGiven ? "💉" : " ")
												</div>
											</td>
										}
									</tr>
								</tbody>
							</table>
						</section>

						<section class="assigned-staff">
							<h4>Ansvarlig personale</h4>
							<div class="staff-list">
								@foreach (var staff in resident.AssignedStaff)
								{
									<span class="staff-pill">@staff</span>
								}
							</div>
						</section>

					</article>
					@* <article class="resident-card">
					<h3>@resident.ResidentName</h3>
					<p><strong>⚠️Risikoniveau: </strong> @resident.RiskLevel</p>
					<p><strong>📝Status: </strong> @resident.Status</p>
					<p><strong>💊Medicintid: </strong> @resident.MedicinTime</p>
					<p><strong>💉PN-tid: </strong> @resident.PnTime</p>
					<p><strong>🗓️Indkøbsdag: </strong> @(resident.GroceryDay?.ToString("dd-MM-yyyy") ?? "-")</p>
					<p><strong>💳Betalingsmetode: </strong>@resident.PaymentMethod</p>
					</article> *@
				}
		</div>
		</main>
			<aside class="right-panel">
				@* Info boks i venstre side - højre side? Kommer vel an på Valdemars main design? *@
				<div class="info-box">
					<h3>Telefonnumre ☎️</h3>
					<p>
						<ul>
							@foreach (var phone in Model.PhoneNumbers)
							{
								<li>@phone</li>
							}
						</ul>
					</p>
				</div>

				<div class="info-box">
					<h3>Afdelingens opgaver📝</h3>
					<ul>
						@foreach (var task in Model.DepartmentTasks)
						{
							<li>@task</li>
						}
					</ul>
				</div>

				<div class="info-box">
					<h3>Særligt ansvar 🔏</h3>
					<ul>
						@foreach (var responsibility in Model.SpecialResponsibilities)
						{
							<li>@responsibility</li>
						}
					</ul>
				</div>
			</aside>
	</section>
}