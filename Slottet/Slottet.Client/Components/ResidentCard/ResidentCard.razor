<div class="bkv-card">

    @* ── HEADER: Navn + Risk dropdown ── *@
    <header class="bkv-header @_draft.RiskCssClass">
        <span class="bkv-navn">@_draft.ResidentName</span>
        <select class="bkv-risk-select" @bind="_draft.RiskLevel">
            <option value="Grøn">Grøn</option>
            <option value="Gul">Gul</option>
            <option value="Rød">Rød</option>
        </select>
    </header>

    <div class="bkv-body">

        @* ── SENESTE STATUS ── *@
        <section class="bkv-section bkv-status-section">
            <span class="bkv-label bkv-label--center">Seneste Status</span>
            <textarea class="bkv-status-input"
                      rows="2"
                      @bind="_draft.LatestStatusNote"
                      placeholder="Skriv seneste status…"></textarea>
        </section>

        <div class="bkv-grid">

            @* ── MEDICIN ── *@
            <section class="bkv-section bkv-medicin-section">
                <span class="bkv-label">Medicin</span>

                <div class="bkv-medicin-slots">
                    @foreach (var med in _draft.MedicineSchedule)
                    {
                        <button type="button"
                                class="bkv-med-slot @(med.IsGiven ? "bkv-med-given" : "bkv-med-not-given")"
                                @onclick="() => med.IsGiven = !med.IsGiven">
                            <span class="bkv-med-tid">@med.Label</span>
                            <span class="bkv-med-ikon">@(med.IsGiven ? "💊" : "·")</span>
                        </button>
                    }

                    @if (_showNewMedicineForm)
                    {
                        <div class="bkv-ny-medicin-form">
                            <input class="bkv-input-small"
                                   type="text"
                                   value="@_newMedicineLabel"
                                   @onchange="e => _newMedicineLabel = FormatTime(e.Value?.ToString())"
                                   placeholder="08:00" />
                            <button type="button" class="bkv-btn-ok" @onclick="AddMedicine">OK</button>
                            <button type="button" class="bkv-btn-annuller"
                                    @onclick="() => { _showNewMedicineForm = false; _newMedicineLabel = string.Empty; }">✕</button>
                        </div>
                    }
                    else
                    {
                        <button type="button" class="bkv-med-add" @onclick="() => _showNewMedicineForm = true">+</button>
                    }
                </div>
            </section>

            @* ── PN ── *@
            <section class="bkv-section bkv-pn-section">
                <span class="bkv-label">PN</span>

                @foreach (var row in _pnRows)
                {
                    var localRow = row;

                    @if (localRow.IsEditing)
                    {
                        @* Editing mode: show inputs + Gem / Annuller *@
                        <div class="bkv-pn-entry bkv-pn-entry--editing">
                            <input class="bkv-input" type="text"
                                   value="@localRow.Entry.TimeOfAdministration"
                                   @onchange="e => localRow.Entry.TimeOfAdministration = FormatTime(e.Value?.ToString())"
                                   placeholder="Tidspunkt" />
                            <input class="bkv-input" type="text"
                                   value="@localRow.Entry.Medication"
                                   @onchange="e => localRow.Entry.Medication = e.Value?.ToString() ?? string.Empty"
                                   placeholder="Præparat" />
                            <input class="bkv-input" type="text"
                                   value="@localRow.Entry.Reason"
                                   @onchange="e => localRow.Entry.Reason = e.Value?.ToString() ?? string.Empty"
                                   placeholder="Årsag" />
                            <span class="bkv-pn-udstedt">Udstedt af: @localRow.Entry.IssuedBy</span>
                            <div class="bkv-pn-actions">
                                <button type="button" class="bkv-btn-ok"
                                        @onclick="() => SavePnRow(localRow)">Gem</button>
                                <button type="button" class="bkv-btn-annuller"
                                        @onclick="() => CancelPnRow(localRow)">Annuller</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        @* Saved mode: read-only display, click to edit *@
                        <div class="bkv-pn-entry bkv-pn-entry--saved"
                             @onclick="() => localRow.IsEditing = true"
                             title="Klik for at redigere">
                            <span class="bkv-pn-field"><strong>@localRow.Entry.TimeOfAdministration</strong></span>
                            <span class="bkv-pn-field">@localRow.Entry.Medication</span>
                            <span class="bkv-pn-field bkv-pn-reason">@localRow.Entry.Reason</span>
                            <span class="bkv-pn-udstedt">Udstedt af: @localRow.Entry.IssuedBy</span>
                        </div>
                    }
                }

                <button type="button" class="bkv-btn-tilfoej" @onclick="AddPN">+ Tilføj PN</button>
            </section>

            @* ── ANSVARLIGT PERSONALE ── *@
            <section class="bkv-section bkv-personale-section">
                <span class="bkv-label">Ansvarligt personale</span>

                <div class="bkv-pills">
                    @foreach (var staffMember in _draft.AssignedStaff)
                    {
                        var localMember = staffMember;
                        <span class="bkv-pill">
                            @localMember
                            <button type="button" class="bkv-pill-remove"
                                    @onclick="() => RemoveStaff(localMember)">×</button>
                        </span>
                    }
                    <button type="button"
                            class="bkv-pill bkv-pill-add"
                            @onclick="() => _showStaffPicker = !_showStaffPicker">+</button>
                </div>

                @if (_showStaffPicker)
                {
                    <div class="bkv-staff-picker">
                        @foreach (var staffMember in AllStaff.Where(n => !_draft.AssignedStaff.Contains(n)))
                        {
                            var localMember = staffMember;
                            <button type="button" class="bkv-staff-pick-btn"
                                    @onclick="() => AddStaff(localMember)">@localMember</button>
                        }
                    </div>
                }
            </section>

            @* ── HANDLEDAG + BETALING ── *@
            <section class="bkv-section bkv-praktisk-section">
                <div class="bkv-praktisk-row">
                    <div class="bkv-praktisk-felt">
                        <span class="bkv-label">Handledag</span>
                        <select class="bkv-select" @bind="_draft.GroceryDay">
                            <option value="">–</option>
                            <option>Mandag</option>
                            <option>Tirsdag</option>
                            <option>Onsdag</option>
                            <option>Torsdag</option>
                            <option>Fredag</option>
                            <option>Lørdag</option>
                            <option>Søndag</option>
                            <option>Handler selv</option>
                        </select>
                    </div>
                    <div class="bkv-praktisk-felt">
                        <span class="bkv-label">Betaling</span>
                        <span class="bkv-betaling-tekst">@(_draft.PaymentMethod ?? "–")</span>
                    </div>
                </div>
            </section>

        </div>
    </div>

    @* ── GEM ÆNDRINGER ── *@
    <div class="bkv-save-bar">
        <button type="button" class="bkv-btn-gem" @onclick="SaveChanges">
            Gem ændringer
        </button>
    </div>

</div>

@code {
    // ── Parameters ────────────────────────────────────────────────────
    [Parameter, EditorRequired] public ResidentCardDto Resident { get; set; } = default!;
    [Parameter]                 public List<string>    AllStaff { get; set; } = new();
    [Parameter]                 public EventCallback   OnSaved  { get; set; }

    // ── Private PN row wrapper ────────────────────────────────────────
    private class PnRow
    {
        public PNEntryDto  Entry     { get; set; } = new();
        public bool        IsEditing { get; set; }
        public PNEntryDto? Snapshot  { get; set; }
    }

    // ── Draft state ───────────────────────────────────────────────────
    private ResidentCardDto _draft               = default!;
    private List<PnRow>     _pnRows              = new();
    private bool            _showNewMedicineForm = false;
    private string          _newMedicineLabel    = string.Empty;
    private bool            _showStaffPicker     = false;

    protected override void OnParametersSet()
    {
        _draft  = DeepCopy(Resident);
        _pnRows = _draft.PNEntries
            .OrderBy(p => ParseTime(p.TimeOfAdministration))
            .Select(p => new PnRow { Entry = p, IsEditing = false, Snapshot = ClonePN(p) })
            .ToList();

        _showNewMedicineForm = false;
        _newMedicineLabel    = string.Empty;
        _showStaffPicker     = false;
    }

    // ── Medicine ──────────────────────────────────────────────────────
    private void AddMedicine()
    {
        if (string.IsNullOrWhiteSpace(_newMedicineLabel)) return;

        var label = _newMedicineLabel.Trim();
        var time  = TimeOnly.TryParse(label, out var t) ? t : TimeOnly.MinValue;

        _draft.MedicineSchedule.Add(new MedicineScheduleItemDto
        {
            Label   = label,
            Time    = time,
            IsGiven = false
        });

        // Keep sorted 00:00 → 23:59
        _draft.MedicineSchedule.Sort((a, b) => a.Time.CompareTo(b.Time));

        _newMedicineLabel    = string.Empty;
        _showNewMedicineForm = false;
    }

    // ── PN ────────────────────────────────────────────────────────────
    private void AddPN()
    {
        _pnRows.Add(new PnRow
        {
            Entry     = new PNEntryDto { IssuedBy = "Logged-in user" },
            IsEditing = true,
            Snapshot  = null
        });
    }

    private void SavePnRow(PnRow row)
    {
        row.Snapshot  = ClonePN(row.Entry);
        row.IsEditing = false;
        _pnRows.Sort((a, b) => ParseTime(a.Entry.TimeOfAdministration).CompareTo(ParseTime(b.Entry.TimeOfAdministration)));
    }

    private void CancelPnRow(PnRow row)
    {
        if (row.Snapshot is null)
        {
            _pnRows.Remove(row);
        }
        else
        {
            row.Entry.TimeOfAdministration = row.Snapshot.TimeOfAdministration;
            row.Entry.Medication           = row.Snapshot.Medication;
            row.Entry.Reason               = row.Snapshot.Reason;
            row.IsEditing                  = false;
        }
    }

    // ── Staff ─────────────────────────────────────────────────────────
    private void AddStaff(string staffMember)
    {
        if (!_draft.AssignedStaff.Contains(staffMember))
            _draft.AssignedStaff.Add(staffMember);
        _showStaffPicker = false;
    }

    private void RemoveStaff(string staffMember)
    {
        _draft.AssignedStaff.Remove(staffMember);
    }

    // ── Save ─────────────────────────────────────────────────────────
    private async Task SaveChanges()
    {
        Resident.RiskLevel        = _draft.RiskLevel;
        Resident.LatestStatusNote = _draft.LatestStatusNote;
        Resident.GroceryDay       = _draft.GroceryDay;
        Resident.AssignedStaff    = new List<string>(_draft.AssignedStaff);
        Resident.MedicineSchedule = _draft.MedicineSchedule
            .Select(m => new MedicineScheduleItemDto { Label = m.Label, Time = m.Time, IsGiven = m.IsGiven })
            .ToList();
        Resident.PNEntries = _pnRows
            .OrderBy(r => ParseTime(r.Entry.TimeOfAdministration))
            .Select(r => r.Entry)
            .ToList();

        await OnSaved.InvokeAsync();
    }

    // ── Time helpers ──────────────────────────────────────────────────
    private static TimeOnly ParseTime(string? s) =>
        TimeOnly.TryParse(s, out var t) ? t : TimeOnly.MaxValue;

    // ── Time auto-format ──────────────────────────────────────────────
    /// <summary>
    /// Formats a raw time string so that `:` is always the 3rd-to-last character.
    /// "845" → "8:45"   |   "0845" → "8:45"   |   "08:45" → "8:45"
    /// </summary>
    private static string FormatTime(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return string.Empty;

        var digits = new string(raw.Where(char.IsDigit).ToArray());

        if (digits.Length < 3) return raw.Trim();

        var minutes  = digits[^2..];
        var hoursStr = digits[..^2];

        if (!int.TryParse(hoursStr, out var hours) ||
            !int.TryParse(minutes,  out var mins))
            return raw.Trim();

        if (hours > 23 || mins > 59) return raw.Trim();

        return $"{hours}:{minutes}";
    }

    // ── Deep copy helpers ─────────────────────────────────────────────
    private static ResidentCardDto DeepCopy(ResidentCardDto src) => new()
    {
        ResidentStatusID   = src.ResidentStatusID,
        ResidentID         = src.ResidentID,
        Date             = src.Date,
        ResidentName     = src.ResidentName,
        IsActive         = src.IsActive,
        RiskLevel        = src.RiskLevel,
        LatestStatusNote = src.LatestStatusNote,
        PaymentMethod    = src.PaymentMethod,
        GroceryDay       = src.GroceryDay,
        AssignedStaff    = new List<string>(src.AssignedStaff),
        MedicineSchedule = src.MedicineSchedule
            .Select(m => new MedicineScheduleItemDto { Label = m.Label, Time = m.Time, IsGiven = m.IsGiven })
            .ToList(),
        PNEntries = src.PNEntries.Select(ClonePN).ToList(),
    };

    private static PNEntryDto ClonePN(PNEntryDto src) => new()
    {
        TimeOfAdministration = src.TimeOfAdministration,
        Medication           = src.Medication,
        Reason               = src.Reason,
        IssuedBy             = src.IssuedBy,
    };
}
