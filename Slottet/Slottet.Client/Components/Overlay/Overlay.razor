@if (IsVisible)
{
    @* Backdrop og panel som søskende — ingen event-propagation konflikt.
       Klik på backdrop lukker. Klik på panelet rammer kun panelet. *@

    <div class="overlay-backdrop" @onclick="HandleClose"></div>

    <div class="overlay-panel @SizeClass" id="@PanelId">
        <button class="overlay-close-btn" @onclick="HandleClose" title="Luk">✕</button>
        @ChildContent
    </div>
}
